  <experiments>
    <experiment name="sensitivity-analysis" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="true">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition><![CDATA[ticks >= 2000]]></exitCondition>
      <metrics>
        <metric>clustering-coefficient</metric>
        <metric>average-path-length</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="ergm-dist-param">
          <value value="-2"></value>
          <value value="-1"></value>
          <value value="0"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="ergm-gwesp-param">
          <value value="-0.1"></value>
          <value value="0"></value>
          <value value="2"></value>
          <value value="3"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
