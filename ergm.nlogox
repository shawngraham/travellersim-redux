    <slider x="25" step="0.1" y="135" max="3" width="250" display="ergm-gwesp-param" height="50" min="-1" direction="Horizontal" default="-0.4" variable="ergm-gwesp-param"></slider>
    <slider x="30" step=".1" y="200" max="1" width="250" display="ergm-gwid-param" height="50" min="-3" direction="Horizontal" default="-0.5" variable="ergm-gwid-param"></slider>
    <slider x="20" step=".1" y="255" max="3" width="250" display="ergm-size-param" height="50" min="-1" direction="Horizontal" default="0.0" variable="ergm-size-param"></slider>
    <slider x="25" step="0.1" y="315" max="0" width="250" display="ergm-dist-param" height="50" min="-2" direction="Horizontal" default="0.0" variable="ergm-dist-param"></slider>
    <slider x="25" step="0.1" y="375" max="2" width="250" display="ergm-decay" height="50" min="0.1" direction="Horizontal" default="0.5" variable="ergm-decay"></slider>
    <slider x="30" step="0.01" y="435" max="1" width="250" display="distance-decay-lambda" height="50" min="0" direction="Horizontal" default="0.03" variable="distance-decay-lambda"></slider>
    <slider x="30" step="10" y="490" max="500" width="250" display="ergm-steps-per-tick" height="50" min="10" direction="Horizontal" default="500.0" variable="ergm-steps-per-tick"></slider>
