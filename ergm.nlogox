    <view x="368" wrappingAllowedX="false" y="10" frameRate="30.0" minPycor="0" height="565" showTickCounter="true" patchSize="2.6923076923076925" fontSize="10" wrappingAllowedY="false" width="708" tickCounterLabel="ticks" maxPycor="207" updateMode="0" maxPxcor="260" minPxcor="0"></view>
    <slider x="20" step="-1" y="15" max="0" width="250" display="ergm-edges-param" height="50" min="-8" direction="Horizontal" default="-4.0" variable="ergm-edges-param"></slider>
