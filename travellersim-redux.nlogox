;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; EXPORT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to export-network
  let filename (word "network-export-" ticks ".csv")
  if file-exists? filename [ file-delete filename ]
  file-open filename

  file-print "source,target,weight,source_attr,target_attr"

  ;ask connections with [travel-count > 0.01] [
  ask connections [
    let s    [site-id]       of end1
    let t    [site-id]       of end2
    let w    travel-count
    let s_at [importance] of end1
    let t_at [importance] of end2
    file-print (word s "," t "," w "," s_at "," t_at)
  ]

  file-close
  user-message (word "Network exported: "
    count connections with [travel-count > 0.01] " links saved.")
end


to-report average-importance
  report mean [importance] of sites
end

;;;;; load old original travellersim maps
;; Declare globals and breeds at the very top of your program


to setup-map
  file-close-all
  set maps "tibervalley3.png"
  let map-found? true
  
  carefully [
    import-pcolors maps
  ] [
    set map-found? false
    user-message (word "The selected map--\"" maps "\"--was not found.")
  ]
  
  if not map-found? [ stop ]

  ;; Calculate scale based on red patches
  ;; 1. Identify the scale bar patches
  let red-patches patches with [ shade-of? pcolor 133.4 ]
  let num-red-patches count red-patches

  ;; 2. Calculate meters-per-patch dynamically
  ;; If the red bar = 20km, then 1 patch = 20,000 / number of patches
  ifelse num-red-patches > 0 [
    set meters-per-patch (20000 / num-red-patches)
    
    ;; Optional: the 'scale' variable you were using
    ;; If you want scale to be 'meters per 1/2 patch', keep your math:
    set scale 0.5 * num-red-patches 
  ] [
    ;; Fallback if no red patches are found to avoid division by zero
    user-message "Warning: No red scale bar found. Defaulting to 100m per patch."
    set meters-per-patch 100
  ]
  
  print (word "Map Loaded. Each patch is " precision meters-per-patch 2 " meters wide.")
end   

to setup-settlements
  clear-turtles
  clear-links
  
  set-default-shape sites "house"
  set area-min-val 0
  set area-max-val 1000 

  ;; Reset the tracking variable
  ask patches [ set load-checked? false ]

  ;; Loop through patches in the VIOLET range (112-120)
  ask patches with [ violet-ish? pcolor and not load-checked? ] [
    
    ;; 1. Find all contiguous violet-ish patches starting from this one
    let clump find-clump self
    
    ;; 2. Mark the whole clump immediately so we don't sprout here again
    ask clump [ set load-checked? true ]
    
    ;; 3. Find the visual center of the clump
    let avg-px mean [pxcor] of clump
    let avg-py mean [pycor] of clump
    let center-patch min-one-of clump [ distancexy avg-px avg-py ]
    
    ask center-patch [
      sprout-sites 1 [
        set site-id who
        
        ;; Calculate area/importance based on the number of pixels in the blotch
        set initial-area (count clump * 50) 
        set scaled-area 100 * (initial-area - area-min-val) / ((area-max-val - area-min-val) + 0.1)
        set importance 500 ;; or could set importance scaled-area
        
        set shape "house"
        let assigned-hue (5 + (who * 17) mod 130)
        set base-color assigned-hue
        set color base-color

        ;; 4. Hatch travellers
        let initial-pop max (list 1 (round (initial-area / 200)))
        hatch-travellers initial-pop [
        set shape "person"
        ;set color yellow
        set size  1.5
        set current-site myself
        set my-home myself
        set is-traveling? false
        set last-importance-seen [importance] of myself
        set pen-size 1.5
        set color [color] of myself
        pen-up
        ]
      ]
    ]
    
    ;; 5. Change the pixels to white so the house is clearly visible
    ask clump [ set pcolor white ]
  ]
  ask connections [ set hidden? true ]
  set initial-color-count count-unique-site-colors
  set last-color-count 0
  set stability-ticks 0
  
  reset-ticks
end

;; --- Helper Reporters ---

;; This defines your site color range (112 to 120)
to-report violet-ish? [ c ]
  report (c >= 112 and c <= 120)
end

;; This gathers all connected patches of that color range
to-report find-clump [ start-patch ]
  let clump (patch-set start-patch)
  let frontier (patch-set start-patch)
  
  while [ any? frontier ] [
    ;; FIXED: Use (patch-set [neighbors] of frontier) to flatten the list of agentsets
    ;; This ensures all contiguous pixels are caught in one pass.
    let candidates (patch-set [neighbors] of frontier) with [ 
      violet-ish? pcolor and not member? self clump 
    ]
    
    set clump (patch-set clump candidates)
    set frontier candidates
  ]
  report clump
end

to cleanup-duplicate-sites
  ;; We ask all sites to check if they have a neighbor that is also a site
  ask sites [
    ;; Look for any other site within 1.5 patches (includes diagonals)
    let nearby-sites other sites in-radius 1.5
    
    if any? nearby-sites [
      ;; TIE-BREAKER: If two sites are neighbors, only one should die.
      ;; We say: "If my ID (who) is higher than my neighbor's ID, I will die."
      ;; This ensures we don't accidentally kill BOTH neighboring sites.
      if any? nearby-sites with [ who < [who] of myself ] [
        
        ;; 1. Kill the travellers belonging to this site so they don't wander 
        ;; aimlessly to the edge of the map.
        let my-homeless-travellers travellers with [ my-home = myself ]
        ask my-homeless-travellers [ die ]
        
        ;; 2. Kill the site itself
        die
      ]
    ]
  ]
end

;;;;;reporters for runs ;;;

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; REPORTERS — Hierarchy & Importance Distribution
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Gini coefficient of site importance (0 = perfectly equal, 1 = fully concentrated)
;; Classic inequality measure; tracks how polarised the hierarchy has become
to-report gini-importance
  let vals sort [importance] of sites
  let n length vals
  if n = 0 [ report 0 ]
  let indexed-sum 0
  let idx 1
  foreach vals [ v ->
    set indexed-sum indexed-sum + (idx * v)
    set idx idx + 1
  ]
  let total-sum sum vals
  if total-sum = 0 [ report 0 ]
  report (2 * indexed-sum) / (n * total-sum) - (n + 1) / n
end

;; Importance of the single most dominant site
to-report max-importance
  report max [importance] of sites
end

;; Mean importance across all sites
to-report mean-importance
  report mean [importance] of sites
end

;; Standard deviation of importance — low value signals the system has stabilised
to-report sd-importance
  report standard-deviation [importance] of sites
end

;; Ratio of the top site's importance to the mean — a "primacy index"
;; Values >> 1 indicate a primate centre has emerged
to-report primacy-index
  let m mean-importance
  if m = 0 [ report 0 ]
  report max-importance / m
end

;; Number of sites more than 2× the mean importance — the "elite tier" count
to-report dominant-site-count
  let threshold mean-importance * 2
  report count sites with [importance > threshold]
end

;; site-id of the current most important site (useful for tracking which site wins)
to-report leading-site-id
  report [site-id] of max-one-of sites [importance]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; REPORTERS — Flow & Visitor Activity
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Total visitor-events recorded across all sites this tick
to-report total-flow-this-tick
  report sum [visitors-count] of sites
end

;; Proportion of travellers currently in transit (0–1)
;; High values = active landscape; low = stagnant movement
to-report proportion-traveling
  let total count travellers
  if total = 0 [ report 0 ]
  report count travellers with [is-traveling?] / total
end

;; Which site is receiving the most visitors RIGHT NOW
to-report busiest-site-id
  report [site-id] of max-one-of sites [visitors-count]
end

;; Flow to the top site as a share of all flow — concentration of traffic
to-report flow-concentration
  let total total-flow-this-tick
  if total = 0 [ report 0 ]
  report max [visitors-count] of sites / total
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; REPORTERS — Network Structure
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Count of active links (travel-count above noise floor)
to-report active-link-count
  report count connections with [travel-count > 0.1]
end

;; Network density: active links as a proportion of all possible directed links
;; n*(n-1) is the maximum possible directed edges for n sites
to-report network-density
  let n count sites
  if n < 2 [ report 0 ]
  report active-link-count / (n * (n - 1))
end

;; Mean travel-count across active links — overall flow intensity in the network
to-report mean-link-weight
  let active connections with [travel-count > 0.1]
  if not any? active [ report 0 ]
  report mean [travel-count] of active
end

;; In-degree of the most connected site (how many unique origins send traffic to it)
to-report max-in-degree
  report max [count my-in-connections with [travel-count > 0.1]] of sites
end

;; The site-id of the highest in-degree site (the network hub)
to-report hub-site-id
  report [site-id] of max-one-of sites [
    count my-in-connections with [travel-count > 0.1]
  ]
end

;; Number of sites that receive NO active inbound traffic — isolated nodes
to-report isolated-site-count
  report count sites with [
    not any? my-in-connections with [travel-count > 0.1]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; REPORTERS — Stability / Convergence
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Coefficient of variation of importance (sd / mean) — scale-free instability measure
;; Useful as a BehaviorSpace stop condition: stop when this drops below a threshold
to-report importance-cv
  let m mean-importance
  if m = 0 [ report 0 ]
  report sd-importance / m
end

;; Rank-order correlation between current importance and initial scaled-area
;; Spearman's rho approximation: 1 = model reproduces input hierarchy, 
;; -1 = model has completely inverted it, 0 = no relationship
to-report rank-correlation-importance-vs-area
  let imp-ranks rank-list [importance] of sites
  let area-ranks rank-list [scaled-area] of sites
  let n length imp-ranks
  if n < 2 [ report 0 ]
  let d-sq-sum sum (map [ [r1 r2] -> (r1 - r2) ^ 2 ] imp-ranks area-ranks)
  report 1 - (6 * d-sq-sum) / (n * (n ^ 2 - 1))
end

;; Helper: returns a list of rank positions for a given list of values
;; Ties receive the average rank
to-report rank-list [vals]
  let sorted-vals sort vals
  ;; We map over the original list and call our helper for each value
  report map [ v -> get-average-rank v sorted-vals ] vals
end

;; Helper: calculates the average rank of a value in a sorted list
to-report get-average-rank [v sorted-list]
  let rank-sum 0
  let rank-count 0
  let idx 1
  
  foreach sorted-list [ sv ->
    if sv = v [
      set rank-sum rank-sum + idx
      set rank-count rank-count + 1
    ]
    set idx idx + 1
  ]
  
  ;; Return the average rank
  report rank-sum / rank-count
end

;;add this in behaviour space to stop if no meaningful changes happening:
;; In BehaviorSpace "Stop condition" field:
;;importance-cv < 0.05

to update-color-stability
  let current-count count-unique-site-colors
  ifelse current-count = last-color-count [
    set stability-ticks stability-ticks + 1
  ] [
    set last-color-count current-count
    set stability-ticks 0
  ]
end

;; Pure reporter — just reads the state:

to-report is-color-converged-and-stable? [ required-ticks ]
  ;; Must have seen a real drop AND then been stable for required-ticks
  report (count-unique-site-colors < initial-color-count * 0.6) 
      and (stability-ticks >= required-ticks)
end


;; Returns the number of unique sites colors currently in existence
to-report count-unique-site-colors
  report length remove-duplicates [color] of sites
end

;; Returns the percentage of the population belonging to the most common color
;; (The height of the tallest bar in your histogram)
to-report color-dominance-index
  let total count sites
  if total = 0 [ report 0 ]
  let color-counts map [ c -> count sites with [color = c] ] (remove-duplicates [color] of sites)
  report (max color-counts / total) * 100
end

;; Shannon Entropy of colors: measures how "mixed" the colors are.
;; High value = many colors evenly spread. Low (0) = everyone is the same color.
to-report color-entropy
  let total count sites
  if total = 0 [ report 0 ]
  let distinct-colors remove-duplicates [color] of sites
  let entropy 0
  foreach distinct-colors [ c ->
    let p (count sites with [color = c] / total)
    set entropy entropy + (p * ln p)
  ]
  report -1 * entropy
end

;; Returns the actual counts as a list (e.g., [[color1 count] [color2 count]])
;; WARNING: Only use this if you are using "Table" output in BehaviorSpace
to-report raw-color-distribution
  let distinct-colors sort remove-duplicates [color] of sites
  report map [ c -> list c (count travellers with [color = c]) ] distinct-colors
end]]></code>
