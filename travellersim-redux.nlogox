<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[extensions [csv rnd]

breed [sites site]
breed [travellers traveller]
directed-link-breed [connections connection]

globals [
  min-easting
  min-northing
  meters-per-patch
  area-max-val
  area-min-val
  ;;for old travellersim maps
  maps  ;; This should hold the filename/path string
  scale
  last-color-count
  stability-ticks
  initial-color-count

]

sites-own [
  site-id
  initial-area
  scaled-area
  importance       ;; W in Rihll-Wilson — site size/benefit
  visitors-count           ;; Analytical Tij sum for this site as destination j
  base-color
]

travellers-own [
  current-site
  target-site
  is-traveling?
  last-importance-seen 
  my-home
]

connections-own [
  travel-count
]

patches-own [ 
  load-checked? 
]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SLIDER PARAMETERS (define in Interface tab)
;;
;;   alpha-exponent       [0.0 – 3.0, default 1.0]  Origin W exponent (Wᵢᵅ)
;;   beta-exponent        [0.0 – 3.0, default 1.0]  Destination W exponent (Wⱼᵝ)
;;   distance-decay-lambda [0.0 – 1.0, default 0.05] λ in exp(−λ·d) decay
;;   gamma                [0.0 – 100, default 10]    Feedback speed ε = gamma/100
;;   social-weight        [0.0 – 2.0, default 0.5]   Maintenance cost κ
;;   movement-probability [0.0 – 100, default 5]     Chance traveller moves per tick (visual only)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SETUP
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup
  clear-all
  ask patches [ set pcolor white ]
  set meters-per-patch 100

  let csv-file "sites-short-data.csv"
  if not file-exists? csv-file [ user-message "CSV file not found!" stop ]
  let raw-data but-first csv:from-file csv-file

  set area-max-val max map [ row -> item 3 row ] raw-data
  set area-min-val min map [ row -> item 3 row ] raw-data

  let eastings  map [ row -> item 1 row ] raw-data
  let northings map [ row -> item 2 row ] raw-data
  set min-easting  min eastings
  set min-northing min northings

  resize-world 0 (round ((max eastings - min-easting)  / meters-per-patch) + 20)
               0 (round ((max northings - min-northing) / meters-per-patch) + 20)
  set-patch-size (700 / max-pxcor)

  foreach raw-data [ row ->
    create-sites 1 [
      set site-id      (item 0 row)
      set label        site-id
      set label-color  black  
      set initial-area (item 3 row)
      set scaled-area  100 * (initial-area - area-min-val) / ((area-max-val - area-min-val) + 0.1)

      setxy ((item 1 row) - min-easting)  / meters-per-patch
            ((item 2 row) - min-northing) / meters-per-patch

      set shape "house"
      let assigned-hue (5 + (who * 17) mod 130)
      set base-color   assigned-hue
      set color        base-color
      set importance scaled-area   ;; Wⱼ initialised from physical area

      ;; Spawn visual travellers proportional to initial area
      let initial-pop max (list 1 (round (initial-area / 200)))
      hatch-travellers initial-pop [
        set shape "person"
        ;set color yellow
        set size  1.5
        set current-site myself
        set my-home myself
        set is-traveling? false
        set last-importance-seen [importance] of myself
        set pen-size 1.5
        set color [color] of myself
        pen-up
      ]
    ]
  ]
  
  ask connections [ set hidden? true ]
  set initial-color-count count-unique-site-colors
  set last-color-count 0
  set stability-ticks 0
  reset-ticks
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; GO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to go
  ;; Reset visitor counts for this tick to measure current "Flow"
  ask sites [ set visitors-count 0 ]

  ask travellers [
    ifelse not is-traveling? [
      ;; Move based on probability
      if (random-float 100 < movement-probability) [
        let origin current-site
        let potential-targets other sites
        
        if any? potential-targets [
          ;; GRAVITY CHOICE: Probability ~ (Wi^alpha * Wj^beta * e^-lambda*d)
          ;; distance converted to metres for consistent scaling across CSV and map modes
              let choice rnd:weighted-one-of potential-targets [
              (([importance] of origin ^ alpha-exponent) *
              (importance ^ beta-exponent) *
             (exp (- distance-decay-lambda * (distance origin * meters-per-patch))))
          ]
           
         if choice != current-site [
            set last-importance-seen [importance] of current-site
            set target-site choice
            set is-traveling? true
            face target-site
            pen-down
          ]
        ]
      ]
    ] [
      ;; traveller in transit
      fd 1
      if distance target-site < 1 [
        move-to target-site
        set current-site target-site
        pen-up
        
        ;; --- GRAHAM & STEINER (2006) AGENT LOGIC ---
        ;; 1. Register the visit (The "Flow" in the RW equation)
        ask current-site [ set visitors-count visitors-count + 1 ]
        let destination current-site
        let source-home my-home
        if source-home != destination [
        ask source-home [
          if not out-connection-neighbor? destination [
              
            create-connection-to destination [ set travel-count 0 set hidden? true]
            
          ]
          ask out-connection-to destination [
            set travel-count travel-count + 1
          ]
        ]
        ]
        ;; 2. Reflected Glory / Color Diffusion logic
        ifelse [importance] of current-site > last-importance-seen [
          ;; If destination is more important, traveller adopts its influence
          set color [color] of current-site
        ] [
          ;; If traveller comes from more "glory," destination adopts traveller's color
          ask current-site [ set color [color] of myself ]
        ]
        
        set last-importance-seen [importance] of current-site
        set is-traveling? false
        set target-site nobody
        
      ]
    ]
  ]

  update-site-variables
  update-color-stability
  ask connections [ set hidden? true ] ; just to catch any; we want to keep track of the connections, but we only want to see traveller traces.
  if is-color-converged-and-stable? 500 [stop]
  tick  
end



;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; RIHLL-WILSON SITE UPDATE
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to update-site-variables
  ;; Rihll-Wilson equation:
  ;;   Wⱼ(t+1) = Wⱼ(t) + ε · [ Σᵢ Tᵢⱼ  −  κ · Wⱼ(t) ]
  ;;
  ;; ε = gamma / 100   (feedback speed)
  ;; κ = social-weight  (maintenance cost)
  ;; Wj(t+1) = Wj(t) + epsilon * [ Flow - (kappa * Wj(t)) ]
  let epsilon (gamma / 100)
  let kappa social-weight

  ;; We need a scaling constant because 1 agent visit might be "worth" 
  ;; more than 1 unit of importance.
  let flow-sensitivity 10 
  let max-imp max [importance] of sites   
  
  ask sites [
    ;; growth = feedback * (Incoming-Flow - Maintenance-Cost)
    let growth epsilon * ((visitors-count * flow-sensitivity) - (kappa * importance))
    set importance importance + growth

    ;; Floors to prevent total extinction of small sites
    if importance < 1 [ set importance 1 ]
    ;; DYNAMIC RESIZING
  ;; Calculate the max importance currently in the world to scale visuals
    set size 1 + 6 * (importance / max-imp)   ;; ← scales between 1 and 6
    
    ;; Visuals: size encodes Importance; color intensity shifts with importance
    
    ;; Decay link visual travel counts
    ask my-out-connections [ set travel-count travel-count * 0.95 ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; LINK VISUALS (optional call from Interface button)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

